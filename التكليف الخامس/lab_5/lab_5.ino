/*
 * مشروع: عداد من 1 إلى 9 باستخدام ATmega328P
 * الشاشة: 7-segment (أنود مشترك)
 * المنفذ المستخدم: PORTB (PB0 إلى PB6)
 */

#include <avr/io.h>      // مكتبة للتعامل مع منافذ ATmega328P
#include <util/delay.h>  // مكتبة للتأخير الزمني

// مصفوفة تحتوي على أكواد الأرقام من 1 إلى 9
// هذه الأكواد خاصة بالشاشة 7-segment نوع (أنود مشترك)
// 0 = تشغيل القطعة، 1 = إطفاء القطعة
unsigned char digits[] = {
    0xF9,   // الرقم 1
    0xA4,   // الرقم 2
    0xB0,   // الرقم 3
    0x99,   // الرقم 4
    0x92,   // الرقم 5
    0x82,   // الرقم 6
    0xF8,   // الرقم 7
    0x80,   // الرقم 8
    0x90    // الرقم 9
};

int main(void)
{
    // تعيين جميع أطراف PORTB كمخرجات (لأنها موصولة بالشاشة)
    // 0xFF = 11111111 (جميع الأطراف 8 مخرجات)
    DDRB = 0xFF;
    
    int i = 0;    // متغير لتحديد الرقم الحالي (0 يعني الرقم 1)
    
    while(1)      // حلقة لا نهائية
    {
        // إرسال كود الرقم إلى PORTB (الشاشة)
        PORTB = digits[i];
        
        // الانتظار نصف ثانية (500 ميللي ثانية)
        _delay_ms(500);
        
        // الانتقال إلى الرقم التالي
        i++;
        
        // إذا وصلنا إلى الرقم 9 (يعني i = 9)، نرجع إلى 1
        if(i == 9)
        {
            i = 0;  // يعود إلى الرقم 1
        }
    }
    
    return 0;  // لن تصل到这里 أبداً (لأن while(1) لا نهائي)
}
